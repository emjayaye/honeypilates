# Supabase project credentials. Get these from
# https://app.supabase.com/project/<your-project>/settings/api
# Both vars MUST be prefixed EXPO_PUBLIC_ to be exposed to the client bundle.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe (Phase 4). Publishable key only — server-side keys live in
# Supabase Edge Function secrets, never in the app bundle.
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
